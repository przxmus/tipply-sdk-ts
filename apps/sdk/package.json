{
  "name": "tipply-sdk-ts",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Tipply API",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "tipply",
    "sdk",
    "typescript",
    "api",
    "streaming"
  ],
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./public": {
      "types": "./dist/public.d.ts",
      "default": "./dist/public.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "default": "./dist/errors.js"
    }
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "bun run clean && bun run build:js && bun run build:types",
    "build:js": "bun run scripts/build.mjs",
    "build:types": "bunx tsc --project tsconfig.types.json",
    "clean": "rm -rf dist",
    "typecheck": "bunx tsc --project tsconfig.json --noEmit",
    "test": "bun run build && bun test && bun run test:types",
    "test:types": "bunx tsd",
    "test:live": "bun run build && bun test tests/live"
  },
  "devDependencies": {
    "tsd": "^0.33.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "socket.io-client": "2.5.0",
    "zod": "^4.3.6"
  }
}
