---
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Tipply SDK Docs</title>
    <style>
      :root {
        color-scheme: light;
        --bg: #f5efe7;
        --panel: rgba(255, 255, 255, 0.72);
        --text: #1f2937;
        --muted: #5b6472;
        --accent: #0f766e;
        --accent-2: #e879f9;
      }
      body {
        margin: 0;
        min-height: 100vh;
        font-family: ui-sans-serif, system-ui, sans-serif;
        background:
          radial-gradient(circle at top left, rgba(232, 121, 249, 0.18), transparent 30%),
          radial-gradient(circle at bottom right, rgba(15, 118, 110, 0.2), transparent 28%),
          var(--bg);
        color: var(--text);
        display: grid;
        place-items: center;
      }
      main {
        width: min(720px, calc(100vw - 32px));
        padding: 40px;
        border: 1px solid rgba(31, 41, 55, 0.08);
        border-radius: 28px;
        background: var(--panel);
        backdrop-filter: blur(18px);
        box-shadow: 0 30px 90px rgba(15, 23, 42, 0.12);
      }
      h1 {
        margin: 0 0 16px;
        font-size: clamp(2.4rem, 6vw, 4.5rem);
        line-height: 0.95;
        letter-spacing: -0.05em;
      }
      p {
        margin: 0 0 22px;
        max-width: 56ch;
        color: var(--muted);
        font-size: 1.05rem;
        line-height: 1.6;
      }
      a {
        color: white;
        background: linear-gradient(135deg, var(--accent), var(--accent-2));
        text-decoration: none;
        padding: 12px 18px;
        border-radius: 999px;
        font-weight: 700;
        display: inline-block;
      }
    </style>
  </head>
  <body>
    <main>
      <h1>Tipply SDK docs</h1>
      <p>Documentation for the TypeScript SDK and its runtime contract. The full reference is built with Astro Starlight and the Rapide theme.</p>
      <a href="/docs/getting-started">Open docs</a>
    </main>
  </body>
</html>
